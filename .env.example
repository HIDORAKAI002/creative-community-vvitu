# Database Configuration
DB_HOST=your_database_host
DB_PORT=3306
DB_USER=your_database_user
DB_PASS=your_database_password
DB_NAME=your_database_name

# Public server status shown on the homepage
PUBLIC_SERVER_IP=your_public_server_ip_or_domain

# Admin User Initialization (First Run Only)
ADMIN_ID=your_admin_id
ADMIN_NAME="Your Admin Name"
ADMIN_ROLLNO=your_admin_roll_number
ADMIN_EMAIL=your_admin_email@example.edu
ADMIN_PERSEMAIL=admin_personal@example.com
ADMIN_PHONE=0000000000
ADMIN_PASS=your_secure_admin_password

# Application Settings
FLASK_PORT=10018
